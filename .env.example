# WindFlex 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ==================== 板子配置 ====================
# 测试板子的固定 IP 地址
BOARD_IP=10.138.219.131

# 测试板子的 SSH 端口
BOARD_SSH_PORT=22

# ==================== 电源配置 ====================
# 电源型号：DLX-30V10AMP（可编程）或 Non-programmable（不可编程）
POWER_MODEL=DLX-30V10AMP

# 串口设备路径（USB 转串口适配器）
SERIAL_DEVICE=/dev/ttyUSB0

# 波特率：9600 或 115200（根据电源规格）
BAUD_RATE=9600

# ==================== Git 平台配置 ====================
# Git 平台：github 或 gitlab
GIT_PLATFORM=gitlab

# Git 仓库 URL
# GitHub: https://github.com/username/repo.git
# GitLab: https://gitlab.example.com/username/repo.git
GIT_URL=https://gitlab.example.com/username/repo.git

# Git 用户名
GIT_USER=username

# Git Personal Access Token
# GitHub 权限要求：repo, read:org, workflow
# GitLab 权限要求：api, read_repository, write_repository
GIT_TOKEN=your_git_token_here

# Jenkins Git 凭证（可选，默认使用上面的 GIT_USER 和 GIT_TOKEN）
# JENKINS_GIT_USER=${GIT_USER}
# JENKINS_GIT_TOKEN=${GIT_TOKEN}

# ==================== LLM 配置 ====================
# LLM Provider: copilot, claude, openai
LLM_PROVIDER=copilot

# LLM API Key
# GitHub Copilot: GitHub Token
# Anthropic Claude: sk-ant-...
# OpenAI: sk-...
LLM_API_KEY=your_llm_api_key_here

# ==================== 其他配置 ====================
# 时区
TZ=Asia/Shanghai

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== Docker 配置 ====================
# Jenkins HTTP 端口（主机映射）
JENKINS_HTTP_PORT=8080

# Jenkins JNLP 端口（主机映射）
JENKINS_JNLP_PORT=50000

# Hardware Service 端口
HARDWARE_SERVICE_PORT=8000

# OpenCLaw Web 端口
OPENCLAW_PORT=3000
